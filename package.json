{
  "name": "ferrite-rs",
  "version": "0.1.0",
  "scripts": {
    "dev": "cargo run --package ferrite-client",
    "start": "cargo run --release --bin ferrite-client",
    "cli": "cargo run --bin ferrite-cli",
    "build": "cargo build",
    "build:release": "cargo build --release",
    "check": "cargo check",
    "test": "cargo test",
    "fmt": "cargo fmt --all",
    "stats": "cloc . --exclude-dir=node_modules,dist,.output,.tanstack,.content-collections,project.inlang,data,paraglide,vendor,.turbo,.next,target",
    "stats:git": "cloc . --exclude-dir=node_modules,dist,.output,.tanstack,.content-collections,project.inlang,data,paraglide,vendor,.turbo,.next,target --vcs git",
    "test:vanilla": "cargo run --package mc-launcher-cli -- --version 1.21.8 --server localhost --no-assets"
  }
}
