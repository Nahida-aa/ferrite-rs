{
  "name": "ferrite-rs",
  "version": "0.1.0",
  "scripts": {
    "dev": "cargo run --package ferrite-client",
    "start": "cargo run --release --bin ferrite-client",
    "cli": "cargo run --bin server-cli",
    "build": "cargo build",
    "build:release": "cargo build --release",
    "check": "cargo check",
    "test": "cargo test",
    "server": "./ferrite-server",
    "scan-lan": "cargo run --package server-cli -- scan-lan",
    "test:vanilla": "cargo run --package mc-launcher-cli -- --version 1.21.8 --username aa",
    "decompile": "cargo run --package mc-src-cli",
    "fmt": "cargo fmt --all",
    "stats": "cloc . --exclude-dir=node_modules,dist,.output,.tanstack,.content-collections,project.inlang,data,paraglide,vendor,.turbo,.next,target,logs",
    "stats:git": "cloc . --exclude-dir=node_modules,dist,.output,.tanstack,.content-collections,project.inlang,data,paraglide,vendor,.turbo,.next,target,logs --vcs git"
  }
}
